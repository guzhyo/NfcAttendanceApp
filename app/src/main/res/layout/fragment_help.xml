<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#f5f3f0">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="使用说明"
        android:textSize="24sp"
        android:textColor="#333"
        android:textStyle="bold"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="15sp"
        android:textColor="#666"
        android:lineSpacingExtra="4dp"
        android:text="本 App 用于记录 NFC 刷卡打卡。\n\n方式一：无障碍服务\n开启后自动检测系统 NFC 事件，刷卡时自动记录。\n\n方式二：HCE 服务\n设为默认 NFC 服务，靠近读卡器时记录。\n\n手动打卡：\n点击打卡页蓝色按钮手动记录。\n\n所有数据仅保存在手机本地，不上传。" />

    <Button
        android:id="@+id/accessibilityBtn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="打开无障碍设置"
        android:layout_marginTop="20dp" />

    <Button
        android:id="@+id/nfcSettingsBtn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="打开 NFC 设置"
        android:textColor="#8a7af0"
        style="@style/Widget.Material3.Button.TextButton" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="v2.0 · 巴巴塔"
        android:textSize="13sp"
        android:textColor="#ccc"
        android:gravity="center"
        android:layout_marginTop="auto"
        android:padding="16dp" />

</LinearLayout>
